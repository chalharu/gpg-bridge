# Server configuration examples
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
SERVER_LOG_LEVEL=info
SERVER_LOG_FORMAT=plain
SERVER_DATABASE_URL=postgres://user:password@localhost:5432/gpg_bridge
# Example for SQLite: sqlite://tmp/gpg_bridge.db
SERVER_DB_MAX_CONNECTIONS=20
SERVER_DB_MIN_CONNECTIONS=1
SERVER_DB_ACQUIRE_TIMEOUT_SECONDS=5
